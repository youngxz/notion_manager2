{
  "manifest_version": 3,
  "name": "Notion AI Config Extractor",
  "version": "1.0",
  "description": "一键提取 Notion AI 账号配置（token_v2, userId, spaceId 等）",
  "permissions": [
    "cookies",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.notion.so/*",
    "https://*.notion.so/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
